-- ========== 1. TP no Brainrot do Alvo ==========
local btnTPBrainrot = makeBtn("🧠 TP no Brainrot do Alvo", Color3.fromRGB(130, 80, 220), 44)
btnTPBrainrot.MouseButton1Click:Connect(function()
    if not targetPlayer then
        notify("Selecione um alvo primeiro (botão abaixo).")
        return
    end
    local tHRP = getHRP(targetPlayer)
    if not tHRP then
        notify("Alvo sem personagem.")
        return
    end
    local brain, dist = findNearestBrainrot(tHRP.Position)
    if brain and dist < 100 then
        smoothTeleport(brain.CFrame)
        task.wait(0.15)
        collectObject(brain)
        notify("TP e roubo no Brainrot de " .. targetPlayer.Name)
    else
        -- Fallback: TP perto do jogador
        smoothTeleport(tHRP.CFrame * CFrame.new(0, 0, -3))
        notify("Brainrot não encontrado perto do alvo. TP próximo.")
    end
end)

