-- ========== 3. Auto Roubo (Auto Petion) ==========
local btnAuto = makeBtn("⚙️ Auto Petion : OFF", Color3.fromRGB(200, 50, 80), 128)
btnAuto.MouseButton1Click:Connect(function()
    autoSteal = not autoSteal
    btnAuto.Text = "⚙️ Auto Petion : " .. (autoSteal and "ON" or "OFF")
    btnAuto.BackgroundColor3 = autoSteal and Color3.fromRGB(50, 180, 80) or Color3.fromRGB(200, 50, 80)
    if autoSteal then
        if stealLoop then stealLoop:Disconnect() end
        stealLoop = RunService.RenderStepped:Connect(function()
            if not autoSteal then return end
            local hrp = getHRP()
            if not hrp then return end
            local brain, dist = findNearestBrainrot(hrp.Position)
            if brain and dist < 40 then
                smoothTeleport(brain.CFrame, 0.1)
                task.wait(0.1)
                collectObject(brain)
            end
        end)
        notify("Auto roubo ATIVADO.")
    else
        if stealLoop then
            stealLoop:Disconnect()
            stealLoop = nil
        end
        notify("Auto roubo DESATIVADO.")
    end
end)

-- ========== 4. Salvar Brainrot e TP [M] ==========
local btnSave = makeBtn("💾 Salvar Brainrot", Color3.fromRGB(40, 40, 50), 170)
btnSave.MouseButton1Click:Connect(function()
    local hrp = getHRP()
    if not hrp then return end
    local brain, dist = findNearestBrainrot(hrp.Position)
    if brain then
        savedBrainrotPos = brain.CFrame
        notify("Brainrot salvo! Use TP [M].")
        btnSave.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        task.wait(0.3)
        btnSave.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    else
        notify("Nenhum Brainrot próximo para salvar.")
        btnSave.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
        task.wait(0.3)
        btnSave.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    end
end)

local btnTP = makeBtn("📌 TP [M] (Brainrot salvo)", Color3.fromRGB(30, 160, 80), 212)
btnTP.MouseButton1Click:Connect(function()
    if savedBrainrotPos then
        smoothTeleport(savedBrainrotPos)
        notify("Teleportado para o Brainrot salvo.")
    else
        notify("Nenhum Brainrot salvo. Use 'Salvar Brainrot' primeiro.")
    end
end)

-- ========== EXTRA: TP para Base do Adversário (Duel) ==========
local btnDuelTP = makeBtn("⚔️ TP Base Adversário (Duel)", Color3.fromRGB(100, 100, 200), 254)
btnDuelTP.MouseButton1Click:Connect(function()
    local myPos = getHRP()
    if not myPos then return end
    local closest = nil
    local minDist = math.huge
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local dist = (plr.Character.HumanoidRootPart.Position - myPos.Position).magnitude
            if dist < minDist and dist < 200 then
                minDist = dist
                closest = plr
            end
        end
    end
    if closest then
        smoothTeleport(closest.Character.HumanoidRootPart.CFrame)
        notify("TP para base de " .. closest.Name)
    else
        notify("Nenhum adversário próximo (use no Duel).")
    end
end)

-- ========== BINDS DE TECLADO ==========
UIS.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.T then
        btnTP.MouseButton1Click:Fire()        -- TP [M]
    elseif input.KeyCode == Enum.KeyCode.P then
        btnSave.MouseButton1Click:Fire()      -- Salvar Brainrot
    elseif input.KeyCode == Enum.KeyCode.O then
        btnSelect.MouseButton1Click:Fire()    -- Abrir seleção de alvo
    elseif input.KeyCode == Enum.KeyCode.I then
        btnAuto.MouseButton1Click:Fire()      -- Ligar/desligar Auto Petion
    elseif input.KeyCode == Enum.KeyCode.U then
        btnTPBrainrot.MouseButton1Click:Fire() -- TP no Brainrot do alvo
    elseif input.KeyCode == Enum.KeyCode.Y then
        btnDuelTP.MouseButton1Click:Fire()    -- TP base adversário
    end
end)

