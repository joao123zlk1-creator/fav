-- ========== TELEPORTE SUAVE (SEM ROLLBACK) ==========
local function smoothTeleport(targetCFrame, duration)
    duration = duration or 0.12
    local char = LocalPlayer.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end

    local startCF = hrp.CFrame
    local startTime = tick()
    local con
    con = RunService.RenderStepped:Connect(function()
        local elapsed = tick() - startTime
        local alpha = math.min(1, elapsed / duration)
        hrp.CFrame = startCF:Lerp(targetCFrame, alpha)
        if alpha >= 1 then
            con:Disconnect()
        end
    end)
    return true
end

-- ========== HELPERS ==========
local function getHRP(plr)
    plr = plr or LocalPlayer
    local char = plr.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function notify(msg)
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "BrainrotTop",
        Text = msg,
        Duration = 2
    })
end

-- Encontra o Brainrot mais próximo de uma posição
local function findNearestBrainrot(position)
    local best, bestDist = nil, math.huge
    for _, obj in ipairs(workspace:GetDescendants()) do
        local name = obj.Name:lower()
        if obj:IsA("BasePart") and (name:find("brainrot") or name:find("brain") or name:find("pet")) then
            local dist = (obj.Position - position).magnitude
            if dist < bestDist then
                bestDist = dist
                best = obj
            end
        elseif obj:IsA("Model") and (name:find("brainrot") or name:find("brain") or name:find("pet")) then
            local part = obj:FindFirstChildWhichIsA("BasePart")
            if part then
                local dist = (part.Position - position).magnitude
                if dist < bestDist then
                    bestDist = dist
                    best = part
                end
            end
        end
    end
    return best, bestDist
end

-- Tenta coletar o objeto (ProximityPrompt ou ClickDetector)
local function collectObject(obj)
    if not obj then return false end
    local function attempt(o)
        local prompt = o:FindFirstChildWhichIsA("ProximityPrompt")
        if prompt then
            fireproximityprompt(prompt)
            return true
        end
        local click = o:FindFirstChildWhichIsA("ClickDetector")
        if click then
            fireclickdetector(click)
            return true
        end
        return false
    end
    if obj:IsA("BasePart") then
        return attempt(obj)
    elseif obj:IsA("Model") then
        for _, desc in ipairs(obj:GetDescendants()) do
            if attempt(desc) then return true end
        end
    end
    return false
end

