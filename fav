--  BOTÃO 4 — TP Posição [T]
-- =============================================
local Btn4 = makeBtn("⚡ TP Posição [T]", Color3.fromRGB(30, 160, 80), 176)

-- Salva posição com clique, TP com T
Btn4.MouseButton1Click:Connect(function()
    local hrp = getHRP()
    if hrp then
        savedPos = hrp.CFrame
        notify("Posição salva! Pressione T para teleportar.")
        Btn4.Text = "⚡ TP Salvo [T] ✓"
    end
end)

UIS.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    -- T = TP para posição salva
    if input.KeyCode == Enum.KeyCode.T then
        local hrp = getHRP()
        if hrp and savedPos then
            hrp.CFrame = savedPos
            notify("Teleportado para posição salva!")
        else
            notify("Nenhuma posição salva! Clique no botão primeiro.")
        end
    end
    -- G = parar loops
    if input.KeyCode == Enum.KeyCode.G then
        tpLoopOn = false
        notify("Loops parados.")
    end
end)
