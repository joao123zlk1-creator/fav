-- =============================================
--  BOTÃO 1 — TP no Brainrot do Jogador Alvo
-- =============================================
local Btn1 = makeBtn("🧠 TP no Brainrot do Alvo", Color3.fromRGB(130, 80, 220), 44)

-- Dropdown de jogadores (clique direito no botão troca alvo)
Btn1.MouseButton1Click:Connect(function()
    local hrp = getHRP()
    if not hrp then notify("Personagem não encontrado!"); return end

    -- Pega todos os jogadores menos você
    local targets = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then table.insert(targets, p) end
    end

    if #targets == 0 then notify("Nenhum jogador encontrado!"); return end

    -- Usa o targetPlayer definido, ou o primeiro disponível
    local tp = targetPlayer
    if not tp or not tp.Parent then tp = targets[1] end

    local tHRP = getHRP(tp)
    if not tHRP then notify("Alvo sem personagem!"); return end

    -- Acha Brainrot perto do alvo
    local brainrot = findBrainrotNear(tHRP.Position)
    if brainrot then
        local pos
        if brainrot:IsA("BasePart") then pos = brainrot.Position
        elseif brainrot:IsA("Model") then
            local p = brainrot:FindFirstChildWhichIsA("BasePart")
            if p then pos = p.Position end
        end
        if pos then
            hrp.CFrame = CFrame.new(pos + Vector3.new(0,3,0))
            task.wait(0.1)
            tryCollect(brainrot)
            notify("TP no Brainrot de " .. tp.Name)
        end
    else
        -- Fallback: TP direto no jogador
        hrp.CFrame = tHRP.CFrame * CFrame.new(0, 0, -3)
        notify("Brainrot não achado, TP no jogador: " .. tp.Name)
    end
end)

