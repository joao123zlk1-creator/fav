-- =============================================
--  HELPERS
-- =============================================
local function getHRP(player)
    local char = (player or LocalPlayer).Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function notify(msg)
    game:GetService("StarterGui"):SetCore("SendNotification",{
        Title="BrainrotTop", Text=msg, Duration=3
    })
end

local function tryCollect(obj)
    if not obj then return end
    local function act(o)
        local cd = o:FindFirstChildOfClass("ClickDetector")
        if cd then fireclickdetector(cd); return true end
        local pp = o:FindFirstChildOfClass("ProximityPrompt")
        if pp then fireproximityprompt(pp); return true end
    end
    if obj:IsA("Model") then
        for _,d in ipairs(obj:GetDescendants()) do if act(d) then return end end
    end
    act(obj)
end

local function findBrainrotNear(position)
    -- Procura o Brainrot mais próximo de uma posição
    local best, bestDist = nil, math.huge
    for _, obj in ipairs(game:GetService("Workspace"):GetDescendants()) do
        if obj.Name:lower():find("brainrot") or obj.Name:lower():find("brain") then
            local pos
            if obj:IsA("BasePart") then pos = obj.Position
            elseif obj:IsA("Model") then
                local p = obj:FindFirstChildWhichIsA("BasePart")
                if p then pos = p.Position end
            end
            if pos then
                local d = (pos - position).Magnitude
                if d < bestDist then bestDist = d; best = obj end
            end
        end
    end
    return best
end

