-- Loop Auto Potion — usa poções do inventário
RunService.Heartbeat:Connect(function()
    if not autoPotion then return end
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChild("Humanoid")
    if hum and hum.Health < hum.MaxHealth * 0.6 then
        -- Tenta usar item de cura do backpack
        local bp = LocalPlayer:FindFirstChild("Backpack")
        if bp then
            for _, tool in ipairs(bp:GetChildren()) do
                if tool.Name:lower():find("potion") or tool.Name:lower():find("heal") then
                    tool.Parent = char
                    task.wait(0.1)
                    local fa = tool:FindFirstChildOfClass("LocalScript")
                        or tool:FindFirstChild("Handle")
                    if fa and fa:IsA("BasePart") then
                        -- equipa e ativa
                        local hum2 = char:FindFirstChild("Humanoid")
                        if hum2 then hum2:EquipTool(tool) end
                    end
                    break
                end
            end
        end
    end
end)

